# ─── Azure AI Foundry ────────────────────────────────────────────────────────
AZURE_AI_PROJECT_CONNECTION_STRING="<region>.api.azureml.ms;<subscription-id>;<resource-group>;<project-name>"
AZURE_AI_FOUNDRY_ENDPOINT="https://<your-hub>.openai.azure.com/"

# ─── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT="https://<your-resource>.openai.azure.com/"
AZURE_OPENAI_API_KEY=""                  # Leave empty when using Managed Identity
AZURE_OPENAI_DEPLOYMENT_GPT4O="gpt-4o"
AZURE_OPENAI_DEPLOYMENT_GPT4O_MINI="gpt-4o-mini"
AZURE_OPENAI_API_VERSION="2025-01-01-preview"

# ─── Azure AI Search (Knowledge Base: CAF/WAF/Patterns) ──────────────────────
AZURE_SEARCH_ENDPOINT="https://<your-search>.search.windows.net"
AZURE_SEARCH_KEY=""                      # Leave empty when using Managed Identity
AZURE_SEARCH_INDEX_CAF="caf-guidelines"
AZURE_SEARCH_INDEX_WAF="waf-pillars"
AZURE_SEARCH_INDEX_PATTERNS="migration-patterns"

# ─── MongoDB (State & Results) ────────────────────────────────────────────────
MONGO_ROOT_PASSWORD="changeme_local"     # Dev only — use Key Vault in production
MONGODB_URI="mongodb://admin:${MONGO_ROOT_PASSWORD}@localhost:27017/architect-framework?authSource=admin"
MONGODB_DATABASE="architect-framework"
MONGODB_COLLECTION_SESSIONS="sessions"
MONGODB_COLLECTION_REPORTS="reports"

# ─── Azure Key Vault ──────────────────────────────────────────────────────────
KEY_VAULT_URL="https://<your-keyvault>.vault.azure.net/"

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_ENV="development"                    # development | staging | production
APP_LOG_LEVEL="INFO"
APP_MAX_FILE_SIZE_MB=50
APP_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# ─── Agent Settings ───────────────────────────────────────────────────────────
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.1
AGENT_PARALLEL_LIMIT=4                   # Max agents running in parallel
AGENT_TIMEOUT_SECONDS=300

# ─── Azure Pricing API ────────────────────────────────────────────────────────
AZURE_PRICING_API="https://prices.azure.com/api/retail/prices"

# ─── Optional: External Cloud Pricing ────────────────────────────────────────
AWS_PRICING_ENABLED=false
GCP_PRICING_ENABLED=false

# ─── Azure Identity (Service Principal for Azure MCP server) ─────────────────
# Used by the mcp-azure Docker container to authenticate Azure API calls
AZURE_TENANT_ID=""
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_SUBSCRIPTION_ID=""

# ─── Pre-configured MCP Servers ──────────────────────────────────────────────
# Internal Docker URLs — do NOT change unless running MCP services on custom ports.
# Set *_ENABLED=true to activate the corresponding MCP enrichment in analyses.
# Start MCP services: docker compose --profile mcp up mcp-azure mcp-devops

# Azure MCP server (azure-migrate, advisor, pricing, cloudarchitect, WAF, etc.)
AZURE_MCP_SERVER_URL="http://mcp-azure:3333/sse"
AZURE_MCP_SERVER_ENABLED=false

# Azure DevOps MCP server (repos, work items, pipelines, wikis, search)
AZURE_DEVOPS_MCP_SERVER_URL="http://mcp-devops:3334/sse"
AZURE_DEVOPS_MCP_SERVER_ENABLED=false
AZURE_DEVOPS_ORG=""           # e.g. "mycompany"
AZURE_DEVOPS_EXT_PAT=""       # PAT with Code(Read), Work Items(Read), Build(Read) scopes

# ─── Object Storage ───────────────────────────────────────────────────────────
# STORAGE_BACKEND: "minio" (local) | "azure" (production) | "disabled" (default)
STORAGE_BACKEND="disabled"

# MinIO — local development (Docker volume: minio_data → /data)
MINIO_ENDPOINT="http://minio:9005"              # backend → MinIO (Docker network)
MINIO_PUBLIC_ENDPOINT="http://localhost:9005"   # browser → MinIO (presigned URLs)
MINIO_ACCESS_KEY="efesto"
MINIO_SECRET_KEY="changeme_local_minio"         # Dev only — use Key Vault in production
MINIO_BUCKET="efesto-artifacts"
MINIO_PRESIGN_EXPIRY_SECONDS=3600

# Azure Blob Storage — production
# Leave AZURE_STORAGE_CONNECTION_STRING empty to use Managed Identity
AZURE_STORAGE_ACCOUNT_NAME=""
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="efesto-artifacts"
